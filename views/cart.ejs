<%- include('./partials/header') %>
    <div class="w-full min-h-screen flex items-start px-20 mt-24 pb-20 gap-10">

        <div class="w-[30%] flex flex-col gap-5">
            <% if(groupedCart.length> 0) { %>
                <% groupedCart.forEach(function(item){ %>
                    <div class="w-full rounded-md overflow-hidden border border-gray-400">
                        <div class="w-full flex justify-center items-center h-80 bg-[<%= item.details.bgcolor %>]">
                            <img class="h-[16rem]"
                                src="data:image/jpeg;base64, <%= item.details.image.toString('base64') %>" alt="">
                        </div>
                        <div class="w-full flex justify-between px-5 py-4 bg-[<%= item.details.panelcolor %>]">
                            <h3 class="text-2xl">
                                <%= item.details.name %>
                            </h3>
                            <div class="flex items-center gap-2">
                                <a href="/cart/decrement/<%= item.details._id %>"
                                    class="w-7 h-7 bg-white flex rounded-full items-center justify-center cursor-pointer">
                                    <i class="ri-subtract-line text-black"></i>
                                </a>

                                <div class="px-2 py-1 rounded-md bg-white text-black">
                                    <%= item.quantity %>
                                </div>

                                <a href="/cart/increment/<%= item.details._id %>"
                                    class="w-7 h-7 bg-white flex rounded-full items-center justify-center cursor-pointer">
                                    <i class="ri-add-line text-black"></i>
                                </a>
                            </div>
                        </div>
                        <div
                            class="flex text-white items-center justify-between px-5 py-3 bg-[<%= item.details.textcolor %>]">
                            <h4 class="text-lg">Net Total</h4>
                            <h2 class="text-lg">₹ <%= (Number(item.details.price) - Number(item.details.discount)) *
                                    item.quantity %>
                            </h2>
                        </div>
                    </div>
                    <% }) %>
                        <% } else { %>
                            <h2 class="text-2xl text-zinc-500">Your cart is empty.</h2>
                            <% } %>
        </div>

        <div class="w-[70%]">
            <h3 class="text-xl">Price Breakdown</h3>
            <div class="px-10 mt-5">
                <div class="flex mt-2">
                    <h4 class="w-1/3">Total MRP</h4>
                    <h4>₹ <%= totalMRP %>
                    </h4>
                </div>
                <div class="flex mt-2">
                    <h4 class="w-1/3">Discount on MRP</h4>
                    <h4>₹ <%= totalDiscount %>
                    </h4>
                </div>
                <div class="flex mt-2">
                    <h4 class="w-1/3">Platform Fee</h4>
                    <h4>₹ 20</h4>
                </div>
                <div class="flex mt-2">
                    <h4 class="w-1/3">Shipping Fee</h4>
                    <h4>FREE</h4>
                </div>
            </div>
            <div class="w-full h-[1px] bg-black mt-10"></div>
            <div class="flex mt-5">
                <h3 class="w-1/3 text-xl">Total Amount</h3>
                <h3 class="font-semibold text-xl text-green-600">₹ <%= bill %>
                </h3>
            </div>
            <form action="">
                <button type="button" class="px-5 py-2 mt-5 rounded-md bg-black text-white font-semibold">Place
                    Order</button>
            </form>
        </div>
    </div>
    <%- include('./partials/footer') %>